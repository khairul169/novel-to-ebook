{
  "name": "storvi",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "NODE_ENV=production bun run src/index.ts",
    "dev:server": "bun --watch run src/index.ts",
    "dev:ui": "cd ui && npm run dev -- --host",
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:ui\"",
    "typegen": "npm run typegen:server && npm run typegen:ui",
    "typegen:server": "kysely-codegen --dialect bun-sqlite --out-file src/db/types.d.ts",
    "typegen:ui": "cd ui && npm run typegen"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/epub-gen": "^0.1.2",
    "@types/jsdom": "^28.0.0",
    "@types/opentype.js": "^1.3.9",
    "@types/sanitize-html": "^2.16.0",
    "better-sqlite3": "^12.6.2",
    "concurrently": "^9.2.1",
    "kysely-codegen": "^0.20.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@epubkit/epub-gen-memory": "1.0.10-aplha.14",
    "@extractus/article-extractor": "^8.0.20",
    "@ghostery/adblocker-puppeteer": "^2.14.1",
    "@google/genai": "^1.44.0",
    "@mozilla/readability": "^0.6.0",
    "@scalar/hono-api-reference": "^0.10.0",
    "blurhash": "^2.0.5",
    "cheerio": "^1.2.0",
    "cron": "^4.4.0",
    "epub": "^2.1.1",
    "epub-gen": "^0.1.0",
    "hono": "^4.12.5",
    "hono-zod-openapi": "^1.1.1",
    "jsdom": "^28.1.0",
    "kysely": "^0.28.11",
    "kysely-bun-worker": "^1.2.1",
    "opentype.js": "^1.3.4",
    "pdftoimg-js": "^0.2.5",
    "puppeteer": "^24.38.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-block-resources": "^2.4.3",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "remove-markdown": "^0.6.3",
    "sanitize-html": "^2.17.1",
    "sharp": "^0.34.5",
    "zod": "^4.3.6"
  }
}
